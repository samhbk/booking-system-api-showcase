# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME="Booking System API Showcase"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# Database
# Local dev: SQLite (default). Docker Compose uses MySQL — see docs/DOCKER.md.
# -----------------------------------------------------------------------------
DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=booking
# DB_USERNAME=booking
# DB_PASSWORD=booking

SESSION_DRIVER=array
SESSION_LIFETIME=120

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# -----------------------------------------------------------------------------
# Cache & Redis
# Use "redis" with Docker; "array" for fast PHPUnit (see phpunit.xml).
# -----------------------------------------------------------------------------
CACHE_STORE=database
# CACHE_STORE=redis

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Mail (log driver = no SMTP required for local dev)
# -----------------------------------------------------------------------------
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# JWT (tymon/jwt-auth) — generate with: php artisan jwt:secret
# Never commit a real JWT_SECRET. CI and PHPUnit use ephemeral values.
# -----------------------------------------------------------------------------
JWT_SECRET=
JWT_TTL=60

# -----------------------------------------------------------------------------
# Booking domain
# -----------------------------------------------------------------------------
BOOKING_DEFAULT_SLOT_MINUTES=60
BOOKING_AVAILABILITY_CACHE_STORE=redis
BOOKING_AVAILABILITY_CACHE_TTL=120
BOOKING_API_RATE_PER_MINUTE=120
BOOKING_AUTH_RATE_PER_MINUTE=10
